// stdlib/loom/engine.flow — Loom Engine: Support Loom + Main Loom Architecture
//
// A Loom Engine is one "octopus":
//   - Support Loom (brain): manages lifecycle, I/O, topology, homeostasis
//   - Main Looms (arms): raw GPU VMs, autonomous dispatch, optional mailbox
//
// Support Loom is .flow orchestration. Main Loom is a GPU VM.
// Multiple Loom Engines can run simultaneously (swarm).
//
// State layout:
//   engine map fields: id, globals_size, topology, n_main, mailbox_id
//   main_ids[i]        → VM IDs of all Main Looms (parallel array)
//   precisions[i]      → precision tier per Main Loom (parallel array)
//
// OctoFlow maps use map_set/map_get. Arrays are separate (parallel to engine).

use "main_loom"

// Engine ID counter (increments per engine_create)
let mut engine_next_id = 1.0

// ═══════════════════════════════════════════════════════════════════
//  ENGINE LIFECYCLE — Brain boots and manages arms
// ═══════════════════════════════════════════════════════════════════

fn engine_create(n_main, globals_size, default_precision, main_ids, precisions)
  // Boot a Loom Engine with n_main Main Looms.
  //
  // n_main:            number of Main Looms to create
  // globals_size:      globals SSBO size per Main Loom (floats)
  // default_precision: precision tier for all Looms (e.g. "Q4_K", "F32")
  // main_ids:          empty array — will be populated with VM IDs
  // precisions:        empty array — will be populated with precision tiers
  //
  // Returns engine map with metadata.

  // Initialize thread pool for async I/O (Support Loom capability)
  loom_threads(4.0)

  // Boot Main Looms
  let mut i = 0.0
  while i < n_main
    let vm = loom_boot(1.0, 0.0, globals_size)
    push(main_ids, vm)
    push(precisions, default_precision)

    // Attach micro-homeostasis (default regulator thresholds)
    main_attach_regulator(vm, 10.0, 5.0, 20.0)

    i = i + 1.0
  end

  // Build engine map
  let mut engine = map()
  map_set(engine, "id", engine_next_id)
  map_set(engine, "globals_size", globals_size)
  map_set(engine, "topology", "parallel")
  map_set(engine, "n_main", n_main)
  map_set(engine, "mailbox_id", 0.0)

  engine_next_id = engine_next_id + 1.0

  return engine
end

fn engine_create_mixed(n_main, globals_size, precision_list, main_ids, precisions)
  // Boot a Loom Engine with per-Loom precision assignments.
  //
  // precision_list: array of precision strings, one per Loom
  //   e.g. ["Q4_K", "Q6_K", "F32", "Q4_K"]

  loom_threads(4.0)

  let mut i = 0.0
  while i < n_main
    let vm = loom_boot(1.0, 0.0, globals_size)
    push(main_ids, vm)
    push(precisions, precision_list[i])

    main_attach_regulator(vm, 10.0, 5.0, 20.0)

    i = i + 1.0
  end

  let mut engine = map()
  map_set(engine, "id", engine_next_id)
  map_set(engine, "globals_size", globals_size)
  map_set(engine, "topology", "parallel")
  map_set(engine, "n_main", n_main)
  map_set(engine, "mailbox_id", 0.0)

  engine_next_id = engine_next_id + 1.0

  return engine
end

fn engine_shutdown(engine, main_ids)
  // Clean teardown: shutdown all Main Looms, release resources.
  let n = map_get(engine, "n_main")
  let mut i = 0.0
  while i < n
    loom_shutdown(main_ids[i])
    i = i + 1.0
  end
  return 0.0
end

// ═══════════════════════════════════════════════════════════════════
//  MAIN LOOM MANAGEMENT — Brain spawns/releases arms
// ═══════════════════════════════════════════════════════════════════

fn engine_spawn(engine, main_ids, precisions, precision)
  // Adaptively add a Main Loom (arm) at specified precision.
  // Returns the new VM ID.
  let globals_size = map_get(engine, "globals_size")
  let vm = loom_auto_spawn(1.0, 0.0, globals_size)
  push(main_ids, vm)
  push(precisions, precision)

  // Attach micro-homeostasis
  main_attach_regulator(vm, 10.0, 5.0, 20.0)

  let old_n = map_get(engine, "n_main")
  map_set(engine, "n_main", old_n + 1.0)
  return vm
end

fn engine_release_last(engine, main_ids, precisions)
  // Release the last Main Loom (simplest — avoids array splice).
  // Parks VM (returns to pool).
  let n = map_get(engine, "n_main")
  if n < 1.0
    return 0.0
  end
  let vm = main_ids[n - 1.0]
  loom_auto_release(vm)
  pop(main_ids)
  pop(precisions)
  map_set(engine, "n_main", n - 1.0)
  return 0.0
end

fn engine_reprecision(precisions, index, new_precision)
  // Change precision tier for a specific Main Loom.
  // Support Loom decision — Main Loom adapts automatically.
  precisions[index] = new_precision
  return 0.0
end

// ═══════════════════════════════════════════════════════════════════
//  TOPOLOGY — Brain organizes how arms work together
// ═══════════════════════════════════════════════════════════════════

fn engine_set_topology(engine, mode)
  // Set topology mode: "parallel" | "sequential" | "hierarchical"
  map_set(engine, "topology", mode)
  return 0.0
end

fn engine_get_topology(engine)
  return map_get(engine, "topology")
end

fn engine_dispatch_all(engine, main_ids, kernel, pc, wg)
  // Dispatch same kernel to ALL Main Looms (parallel topology).
  let n = map_get(engine, "n_main")
  let mut i = 0.0
  while i < n
    main_dispatch(main_ids[i], kernel, pc, wg)
    i = i + 1.0
  end
  return n
end

fn engine_build_all(engine, main_ids)
  // Build command buffers for all Main Looms.
  // Returns array of program handles.
  let n = map_get(engine, "n_main")
  let mut progs = []
  let mut i = 0.0
  while i < n
    let prog = main_build(main_ids[i])
    push(progs, prog)
    i = i + 1.0
  end
  return progs
end

fn engine_run_all(progs)
  // Submit all command buffers (all arms go unhinged simultaneously).
  let n = len(progs)
  let mut i = 0.0
  while i < n
    main_run_prog(progs[i])
    i = i + 1.0
  end
  return n
end

fn engine_free_all(progs)
  // Release all command buffers.
  let n = len(progs)
  let mut i = 0.0
  while i < n
    main_free_prog(progs[i])
    i = i + 1.0
  end
  return n
end

fn engine_exec_all(engine, main_ids)
  // Convenience: build + run + free all Main Looms.
  let progs = engine_build_all(engine, main_ids)
  engine_run_all(progs)
  engine_free_all(progs)
  return map_get(engine, "n_main")
end

fn engine_dispatch_chain(engine, main_ids, kernels, pcs, wgs)
  // Sequential topology: dispatch kernel[0] on Loom[0], then
  // copy output to Loom[1], dispatch kernel[1] on Loom[1], etc.
  // Uses loom_copy for GPU-to-GPU transfer (no CPU roundtrip).
  let n = len(kernels)
  let loom_count = map_get(engine, "n_main")
  let gs = map_get(engine, "globals_size")

  let mut i = 0.0
  while i < n
    if i >= loom_count
      return i
    end

    let vm = main_ids[i]
    main_dispatch(vm, kernels[i], pcs[i], wgs[i])
    let prog = main_build(vm)
    main_run_prog(prog)
    main_free_prog(prog)

    // Copy output to next Loom (if not last)
    if i + 1.0 < n
      if i + 1.0 < loom_count
        let src = main_ids[i]
        let dst = main_ids[i + 1.0]
        loom_copy(src, dst, 0.0, 0.0, gs)
      end
    end

    i = i + 1.0
  end
  return n
end

// ═══════════════════════════════════════════════════════════════════
//  MAILBOX — Inter-Loom communication channels
// ═══════════════════════════════════════════════════════════════════

fn engine_create_mailbox(engine, slot_size, slot_count)
  // Create shared mailbox for inter-Loom communication.
  let mailbox = loom_mailbox(slot_size, slot_count)
  map_set(engine, "mailbox_id", mailbox)
  return mailbox
end

fn engine_get_mailbox(engine)
  return map_get(engine, "mailbox_id")
end

// ═══════════════════════════════════════════════════════════════════
//  POLLING — Brain reads arm status (no messaging, just polling)
// ═══════════════════════════════════════════════════════════════════

fn engine_poll_all(engine, main_ids)
  // Poll all Main Looms for micro-homeostasis state.
  // Returns array of stability arrays: [[maxnorm, scale, flag, pace], ...]
  let n = map_get(engine, "n_main")
  let mut results = []
  let mut i = 0.0
  while i < n
    let state = main_read_stability(main_ids[i], 0.0)
    push(results, state)
    i = i + 1.0
  end
  return results
end

fn engine_all_stable(engine, main_ids)
  // Quick check: are all Main Looms stable?
  let n = map_get(engine, "n_main")
  let mut i = 0.0
  while i < n
    let stable = main_is_stable(main_ids[i], 0.0)
    if stable < 0.5
      return 0.0
    end
    i = i + 1.0
  end
  return 1.0
end

fn engine_health(engine, main_ids)
  // Aggregate engine health summary.
  // Returns map: n_main, n_stable, total_pace, vram_used
  let n = map_get(engine, "n_main")
  let mut n_stable = 0.0
  let mut total_pace = 0.0
  let vram = loom_vram_used()

  let mut i = 0.0
  while i < n
    let state = main_read_stability(main_ids[i], 0.0)
    if state[2] > 0.5
      n_stable = n_stable + 1.0
    end
    total_pace = total_pace + state[3]
    i = i + 1.0
  end

  let mut health = map()
  map_set(health, "n_main", n)
  map_set(health, "n_stable", n_stable)
  map_set(health, "total_pace", total_pace)
  map_set(health, "vram_used", vram)
  return health
end

// ═══════════════════════════════════════════════════════════════════
//  ADAPT — The brain's main loop (runtime adaptation)
// ═══════════════════════════════════════════════════════════════════
//
// engine_adapt() is the Support Loom's decision loop:
//   1. Poll all arms (metrics + stability)
//   2. Check VRAM pressure
//   3. Check utilization → split/merge if needed
//
// Call this periodically (e.g., every N frames or after each layer).

fn engine_adapt(engine, main_ids, precisions)
  // Runtime adaptation — the brain thinks.
  let n = map_get(engine, "n_main")
  if n < 1.0
    return 0.0
  end

  // 1. Poll all arms
  let mut n_unstable = 0.0
  let mut n_idle = 0.0
  let mut i = 0.0
  while i < n
    let state = main_read_stability(main_ids[i], 0.0)
    if state[2] < 0.5
      n_unstable = n_unstable + 1.0
    end
    // Check if arm is idle (stable + low maxnorm)
    if state[2] > 0.5
      if state[0] < 0.001
        n_idle = n_idle + 1.0
      end
    end
    i = i + 1.0
  end

  // 2. If many arms unstable, consider reducing count
  if n_unstable > n / 2.0
    if n > 1.0
      if n_idle > 0.0
        engine_release_last(engine, main_ids, precisions)
      end
    end
  end

  // 3. If all stable and idle arms exist, consider merging
  if n_idle > 1.0
    engine_release_last(engine, main_ids, precisions)
  end

  return n_unstable
end

// ═══════════════════════════════════════════════════════════════════
//  DATA DISTRIBUTION — Brain feeds arms
// ═══════════════════════════════════════════════════════════════════

fn engine_write_all(engine, main_ids, offset, data)
  // Write same data to ALL Main Looms (broadcast).
  let n = map_get(engine, "n_main")
  let mut i = 0.0
  while i < n
    main_write(main_ids[i], offset, data)
    i = i + 1.0
  end
  return n
end

fn engine_write_chunks(engine, main_ids, data, chunk_size)
  // Write different chunks to each Main Loom (scatter).
  let n = map_get(engine, "n_main")
  let mut i = 0.0
  while i < n
    let start = i * chunk_size
    let chunk = array_extract(data, start, chunk_size)
    main_write(main_ids[i], 0.0, chunk)
    i = i + 1.0
  end
  return n
end

fn engine_read_all(engine, main_ids, offset, count)
  // Read from ALL Main Looms (gather).
  // Returns array of result arrays.
  let n = map_get(engine, "n_main")
  let mut results = []
  let mut i = 0.0
  while i < n
    let r = main_read(main_ids[i], offset, count)
    push(results, r)
    i = i + 1.0
  end
  return results
end

// ═══════════════════════════════════════════════════════════════════
//  PRECISION-AWARE DISPATCH — Brain selects kernels per arm
// ═══════════════════════════════════════════════════════════════════

fn engine_dispatch_with_dequant(engine, main_ids, precisions, compute_kernel, compute_pc, compute_wg, dequant_pc, dequant_wg)
  // Dispatch with precision-appropriate dequant on each Main Loom.
  let n = map_get(engine, "n_main")
  let mut i = 0.0
  while i < n
    main_dispatch_with_dequant(main_ids[i], precisions[i], compute_kernel, compute_pc, compute_wg, dequant_pc, dequant_wg)
    i = i + 1.0
  end
  return n
end

fn engine_dispatch_regulated(engine, main_ids, kernel, pc, wg, n_elements)
  // Dispatch with micro-homeostasis on all Main Looms.
  let n = map_get(engine, "n_main")
  let mut i = 0.0
  while i < n
    main_dispatch_regulated(main_ids[i], kernel, pc, wg, 0.0, n_elements)
    i = i + 1.0
  end
  return n
end

fn engine_dispatch_full(engine, main_ids, precisions, compute_kernel, compute_pc, compute_wg, dequant_pc, dequant_wg, n_elements)
  // Full pipeline on all Main Looms: dequant + compute + maxnorm + regulator.
  let n = map_get(engine, "n_main")
  let mut i = 0.0
  while i < n
    main_dispatch_full(main_ids[i], precisions[i], compute_kernel, compute_pc, compute_wg, dequant_pc, dequant_wg, 0.0, n_elements)
    i = i + 1.0
  end
  return n
end

// ═══════════════════════════════════════════════════════════════════
//  OCTOPRESS MANAGEMENT — Brain manages arm weight tiers
// ═══════════════════════════════════════════════════════════════════

fn engine_warm_all(engine, main_ids, data)
  // Compress and load data as warm tier on ALL Main Looms.
  let n = map_get(engine, "n_main")
  let mut i = 0.0
  while i < n
    main_load_warm(main_ids[i], data)
    i = i + 1.0
  end
  return n
end

fn engine_promote_warm_all(engine, main_ids, precisions, dequant_wg)
  // Promote warm -> hot on all Main Looms (precision-aware dequant).
  let n = map_get(engine, "n_main")
  let mut i = 0.0
  while i < n
    let dequant = main_select_dequant(precisions[i])
    if dequant != "none"
      if dequant != "jit"
        main_promote_warm(main_ids[i], dequant, [0.0], dequant_wg)
      end
    end
    i = i + 1.0
  end
  return n
end
